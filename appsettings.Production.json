{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.EntityFrameworkCore": "Error"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL}"
  },
  "Stripe": {
    "SecretKey": "${STRIPE_SECRET_KEY}",
    "PublishableKey": "${STRIPE_PUBLISHABLE_KEY}"
  },
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "bindaddy-api",
    "Audience": "bindaddy-frontend",
    "ExpirationMinutes": 60
  },
  "AllowedHosts": "*"
}
