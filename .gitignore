## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/
*.code-workspace

# Visual Studio cache/options directory
.vs/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache files
*.suo
*.user
*.userosscache
*.sln.docstates

# NuGet Packages
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Rider
.idea/

# Environment variables
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Node modules (if applicable)
node_modules/
npm-debug.log
yarn-error.log

# Build output
dist/
build/

# Temporary files
*.tmp
*.temp
*.log
